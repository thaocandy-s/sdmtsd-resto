{
  "extends": "@resto-hub/config/tsconfig/nextjs.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@resto-hub/ui": ["../../packages/ui/src"],
      "@resto-hub/ui/*": ["../../packages/ui/src/*"],
      "@resto-hub/types": ["../../packages/types/src"],
      "@resto-hub/types/*": ["../../packages/types/src/*"],
      "@resto-hub/utils": ["../../packages/utils/src"],
      "@resto-hub/utils/*": ["../../packages/utils/src/*"]
    }
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": ["node_modules"]
}
